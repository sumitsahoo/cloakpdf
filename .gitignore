# they're throwaway documents the contributor supplies themselves.
tests/fixtures/*.pdf

# Puppeteer profile populated by the e2e runner (CacheStorage, IndexedDB,
# shader caches, etc.). Reused across runs to keep the AI models cached
# on disk; never checked in.
tests/.puppeteer-profile/

# Debug artifacts written by tests/e2e/retrieval-probe.ts.
tests/retrieval-debug/
