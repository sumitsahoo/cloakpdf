{
  "name": "cloakpdf",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc && vp build",
    "preview": "vp preview",
    "prepare": "vp config",
    "test": "vp test run tests/unit",
    "test:watch": "vp test watch tests/unit",
    "test:e2e": "node --experimental-strip-types tests/e2e/ai-tools.e2e.ts",
    "test:compare": "node --experimental-strip-types tests/e2e/compare-variants.ts",
    "generate-icons": "pwa-assets-generator --preset minimal-2023 public/icons/logo.svg && mv public/icons/apple-touch-icon-180x180.png public/icons/apple-touch-icon.png"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/textsplitters": "^1.0.1",
    "@pdfme/pdf-lib": "^6.1.2",
    "jszip": "^3.10.1",
    "langchain": "^1.4.0",
    "lucide-react": "^1.16.0",
    "node-forge": "^1.4.0",
    "ogl": "^1.0.11",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@voidzero-dev/vite-plus-core": "^0.1.21",
    "puppeteer-core": "^25.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.21",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "^0.1.21",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.21"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.20",
      "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.20",
      "serialize-javascript": ">=7.0.3"
    }
  }
